mkdir -p repos
cd repos

git clone https://github.com/wiiu-env/WiiUPluginSystem.git
cd WiiUPluginSystem
make install
cd ../

git clone https://github.com/wiiu-env/WiiUModuleSystem.git
cd WiiUModuleSystem
make install
cd ../

git clone https://github.com/wiiu-env/libkernel.git
cd libkernel
make install
cd ../

git clone https://github.com/wiiu-env/libnotifications.git
cd libnotifications
make install
cd ../

git clone https://github.com/wiiu-env/libmappedmemory.git
cd libmappedmemory
make install
cd ../

rm -rf repos

cp -r x86_x64/bin /opt/devkitpro/devkitPPC/wups/bin